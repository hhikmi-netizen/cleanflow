# CleanFlow — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# Récupérer les valeurs dans : https://supabase.com/dashboard → Project Settings → API

# Supabase — obligatoire
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps — optionnel (Places Autocomplete + MiniMap)
# Créer dans Google Cloud Console → APIs & Services → Credentials
# Activer : Maps JavaScript API, Places API
# Restreindre la clé publique aux Referrers (domaine Vercel + localhost)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
# Clé serveur (jamais exposée côté client) — pour usage futur (Geocoding API server-side)
GOOGLE_MAPS_SERVER_API_KEY=your-google-maps-server-key-here

# Ces variables sont optionnelles : si absentes, les champs adresse restent en saisie libre
# et les boutons Maps ouvrent Google Maps avec l'adresse texte comme fallback.
# La sécurité est entièrement gérée par le RLS PostgreSQL côté Supabase.
# Ne jamais commiter .env.local dans git (déjà dans .gitignore).
